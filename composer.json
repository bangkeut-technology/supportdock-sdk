{
    "name": "bangkeut-technology/supportdock-sdk",
    "version": "0.2.0",
    "description": "SupportDock PHP SDK — submit feedback and manage FAQs from your PHP application",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "supportdock",
        "feedback",
        "faq",
        "support",
        "sdk"
    ],
    "authors": [
        {
            "name": "SupportDock",
            "email": "support@supportdock.io"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "SupportDock\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SupportDock\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
